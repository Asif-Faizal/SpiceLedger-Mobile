# Copy to .env (gitignored) for local runs via VS Code launch configs
# Used with: --dart-define-from-file=.env

BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=secret123

# REST via proxy (accounts, merchant details, login)
# Android emulator: 10.0.2.2 maps to host localhost
# iOS simulator / physical device: use your machine LAN IP or 127.0.0.1
BASE_URL=http://10.0.2.2:8080

# GraphQL direct to graphql service (admin catalog, dashboard, mutations)
GRAPHQL_CLIENT=http://10.0.2.2:8081/graphql

# Optional
REST_API_TIMEOUT=30
ENVIRONMENT=development
