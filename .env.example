# Copy to .env (gitignored) for local runs via VS Code launch configs
# Used with: --dart-define-from-file=.env
#
# Backend: cd ../SpiceLedger-Backend && make up-full-build
# Single gateway on :8080 — REST at /rest/*, GraphQL at /graphql

BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=secret123

# Gateway base URL (Docker exposes :8080 on host)
# Android emulator: 10.0.2.2 → host localhost
# iOS simulator:    127.0.0.1
# Physical device:  your machine LAN IP (e.g. 192.168.1.10)
BASE_URL=http://10.0.2.2:8080

# Optional — omit to use BASE_URL + /graphql automatically
# GRAPHQL_CLIENT=http://10.0.2.2:8080/graphql

REST_API_TIMEOUT=30
ENVIRONMENT=development
